{
  "venvPath": ".",
  "venv": "venv",
  "pythonVersion": "3.9",
  "pythonPlatform": "Darwin",
  "typeCheckingMode": "basic",
  "reportMissingImports": true,
  "reportMissingTypeStubs": false,
  "executionEnvironments": [
    {
      "root": ".",
      "pythonVersion": "3.9",
      "pythonPlatform": "Darwin",
      "extraPaths": [
        "./venv/lib/python3.9/site-packages"
      ]
    }
  ],
  "exclude": [
    "**/__pycache__",
    "**/venv",
    "**/.venv",
    "**/node_modules"
  ]
}
